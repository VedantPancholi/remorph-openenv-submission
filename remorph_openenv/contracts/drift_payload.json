{
  "openapi": "3.0.3",
  "info": {
    "title": "ReMorph Payload Drift API",
    "version": "1.1.0"
  },
  "paths": {
    "/users": {
      "post": {
        "summary": "Create user with nested payload",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserCreateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "UserCreateRequest": {
        "type": "object",
        "required": [
          "user"
        ],
        "properties": {
          "user": {
            "type": "object",
            "required": [
              "f_name",
              "l_name"
            ],
            "properties": {
              "f_name": {
                "type": "string"
              },
              "l_name": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}

