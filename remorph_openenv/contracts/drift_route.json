{
  "openapi": "3.0.3",
  "info": {
    "title": "ReMorph Route Drift API",
    "version": "2.0.0"
  },
  "paths": {
    "/users": {
      "post": {
        "summary": "Create user with nested payload",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserCreateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      }
    },
    "/api/v2/finance/ledger": {
      "get": {
        "summary": "List active transactions",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Ledger entries"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "UserCreateRequest": {
        "type": "object",
        "required": [
          "user"
        ],
        "properties": {
          "user": {
            "type": "object",
            "required": [
              "f_name",
              "l_name"
            ],
            "properties": {
              "f_name": {
                "type": "string"
              },
              "l_name": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    }
  }
}

